    "install:all": "npm run backend:install && npm run frontend:install",
    "prepare": "cd frontend && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "express": "^4.18.4",
    "koffi": "^2.16.0",
    "sharp": "^0.33.0",
    "ws": "^8.13.0"
  }
}
