{
  "name": "magic-vein-plus-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "python backend.py",
    "dev": "cd frontend && npm run dev",
    "backend": "python backend.py",
    "backend:install": "pip install -r requirements.txt",
    "frontend:install": "cd frontend && npm install",
